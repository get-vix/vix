# API Keys for vix
# Copy this file to .env and fill in your keys

ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# PostHog telemetry (optional). Read at build time and embedded into the binary
# via -ldflags (see script/build.sh); not read at runtime. Leave empty to ship
# without analytics.
VIX_POSTHOG_API_KEY=

# Discord release announcements (optional, used by script/publish.sh)
DISCORD_WEBHOOK_URL=
